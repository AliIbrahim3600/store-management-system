  <diagram id="gdcM3IHdNs1E7JGfhdoo" name="Page-1">
    <mxGraphModel dx="1717" dy="1123" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;erDiagram\n    %% ========================================================================\n    %% Supermarket Management System — Entity Relationship Diagram\n    %% ========================================================================\n    %% Enum Reference:\n    %%   PaymentMethod:      CASH | CARD | WALLET\n    %%   EmployeePosition:   CASHIER | STORE_MANAGER | STOCK_KEEPER | WAREHOUSE_WORKER\n    %%   OvertimeStatus:     PENDING | APPROVED | REJECTED\n    %%   NotificationType:   STOCK_ALERT | SALE_ALERT | OVERTIME | SYSTEM\n    %%   RefundStatus:       PENDING | APPROVED | REJECTED\n    %%   AuditAction:        CREATE | UPDATE | DELETE | LOGIN | LOGOUT\n    %%   InventoryTxType:    STOCK_IN | STOCK_OUT | ADJUSTMENT | TRANSFER_IN | TRANSFER_OUT | RETURN\n    %% ========================================================================\n\n    %% ────────────────────────────────────────────────────────────────────────\n    %%  PLATFORM &amp; BRAND LAYER\n    %% ────────────────────────────────────────────────────────────────────────\n\n    BRAND ||--o{ STORE : \&quot;has\&quot;\n    BRAND ||--o{ PRODUCT : \&quot;owns\&quot;\n    BRAND ||--o{ CATEGORY : \&quot;categorizes\&quot;\n    BRAND ||--o{ SUPPLIER : \&quot;works_with\&quot;\n    BRAND ||--o{ CUSTOMER : \&quot;serves\&quot;\n    BRAND |o--o{ USER : \&quot;authenticates\&quot;\n\n    %% ────────────────────────────────────────────────────────────────────────\n    %%  STORE LAYER\n    %% ────────────────────────────────────────────────────────────────────────\n\n    STORE ||--o{ EMPLOYEE : \&quot;employs\&quot;\n    STORE ||--o{ INVENTORY : \&quot;stocks\&quot;\n    STORE ||--o{ SALE : \&quot;processes\&quot;\n    STORE ||--o{ PURCHASE : \&quot;receives\&quot;\n    STORE ||--o{ CASH_REGISTER : \&quot;operates\&quot;\n    STORE ||--o{ INVENTORY_TRANSACTION : \&quot;logs\&quot;\n\n    %% ────────────────────────────────────────────────────────────────────────\n    %%  USER &amp; ROLE / AUTH LAYER\n    %% ────────────────────────────────────────────────────────────────────────\n\n    USER ||--|| ROLE : \&quot;assigned\&quot;\n    USER ||--o| EMPLOYEE : \&quot;optionally linked\&quot;\n    USER ||--o{ NOTIFICATION : \&quot;receives\&quot;\n    USER ||--o{ AUDIT_LOG : \&quot;generates\&quot;\n    USER ||--o{ INVENTORY_TRANSACTION : \&quot;performs\&quot;\n    USER |o--o{ REFUND : \&quot;approves\&quot;\n\n    ROLE ||--o{ ROLE_PERMISSION : \&quot;has\&quot;\n    PERMISSION ||--o{ ROLE_PERMISSION : \&quot;assigned_to\&quot;\n\n    %% ────────────────────────────────────────────────────────────────────────\n    %%  PRODUCT &amp; CATEGORY\n    %% ────────────────────────────────────────────────────────────────────────\n\n    CATEGORY ||--o{ PRODUCT : \&quot;contains\&quot;\n    PRODUCT ||--o{ INVENTORY : \&quot;stocked_as\&quot;\n    PRODUCT ||--o{ SALE_ITEM : \&quot;sold_in\&quot;\n    PRODUCT ||--o{ PURCHASE_ITEM : \&quot;purchased_in\&quot;\n    PRODUCT ||--o{ INVENTORY_TRANSACTION : \&quot;tracks\&quot;\n\n    %% ────────────────────────────────────────────────────────────────────────\n    %%  EMPLOYEE &amp; OPERATIONS\n    %% ────────────────────────────────────────────────────────────────────────\n\n    EMPLOYEE ||--o{ SHIFT : \&quot;works\&quot;\n    EMPLOYEE ||--o{ SALE : \&quot;processes\&quot;\n    EMPLOYEE ||--o{ PURCHASE : \&quot;initiates\&quot;\n    EMPLOYEE ||--o{ OVERTIME_REQUEST : \&quot;requests\&quot;\n    EMPLOYEE ||--o{ REFUND : \&quot;issues\&quot;\n\n    CASH_REGISTER ||--o{ SHIFT : \&quot;tracks\&quot;\n\n    %% ────────────────────────────────────────────────────────────────────────\n    %%  PURCHASING\n    %% ────────────────────────────────────────────────────────────────────────\n\n    SUPPLIER ||--o{ PURCHASE : \&quot;supplies\&quot;\n    PURCHASE ||--o{ PURCHASE_ITEM : \&quot;includes\&quot;\n\n    %% ────────────────────────────────────────────────────────────────────────\n    %%  SALES\n    %% ────────────────────────────────────────────────────────────────────────\n\n    CUSTOMER |o--o{ SALE : \&quot;makes\&quot;\n    SALE ||--o{ SALE_ITEM : \&quot;includes\&quot;\n    SALE ||--o{ PAYMENT : \&quot;paid_by\&quot;\n    SALE |o--o{ REFUND : \&quot;returned_in\&quot;\n\n    %% ────────────────────────────────────────────────────────────────────────\n    %%  LEGEND — Symbol Reference\n    %% ────────────────────────────────────────────────────────────────────────\n\n    LEGEND {\n        string prim_key \&quot;Primary Key — uniquely identifies every row\&quot;\n        string for_key \&quot;Foreign Key — references PK of a related table\&quot;\n        string uni_key \&quot;Unique Key — value must not repeat\&quot;\n        string nullable \&quot;Field is optional — may be NULL\&quot;\n        string dec_10_2 \&quot;Fixed-decimal: stores up to 99,999,999.99\&quot;\n        string def_zero \&quot;Default value of 0 if not provided\&quot;\n        string auto_calc \&quot;Computed automatically by the system\&quot;\n        string enum_type \&quot;Restricted to a predefined list of values\&quot;\n        string uniq_per_brand \&quot;Unique within a single Brand only\&quot;\n        string uniq_global \&quot;Unique across all Brands\&quot;\n    }\n\n    CARDINALITY {\n        string one_to_many \&quot;|| -o{  : One (mandatory) to Many (optional)\&quot;\n        string one_to_one \&quot;|| -||  : One (mandatory) to One (mandatory)\&quot;\n        string zero_to_many \&quot;|o -o{  : Zero-or-One to Many (optional)\&quot;\n        string zero_to_one \&quot;|o -||  : Zero-or-One to One (mandatory)\&quot;\n        string many_to_many \&quot;}o -o{  : Many to Many (via junction table)\&quot;\n        string one_to_opt \&quot;|| -o|  : One (mandatory) to One (optional)\&quot;\n        string left_sym \&quot;LEFT  = minimum cardinality on source\&quot;\n        string right_sym \&quot;RIGHT = maximum cardinality on target\&quot;\n    }\n\n    %% ========================================================================\n    %%  ENTITY ATTRIBUTES\n    %% ========================================================================\n\n    BRAND {\n        uuid id PK\n        string name\n        string logo \&quot;nullable\&quot;\n        string email \&quot;nullable\&quot;\n        string phone \&quot;nullable\&quot;\n        string address \&quot;nullable\&quot;\n        string taxNumber \&quot;nullable\&quot;\n        boolean isActive\n        datetime createdAt\n        datetime updatedAt\n    }\n\n    STORE {\n        uuid id PK\n        uuid brandId FK\n        string name\n        string code \&quot;UK with Brand\&quot;\n        string address \&quot;nullable\&quot;\n        string city \&quot;nullable\&quot;\n        string phone \&quot;nullable\&quot;\n        string openingTime \&quot;HH:MM, nullable\&quot;\n        string closingTime \&quot;HH:MM, nullable\&quot;\n        boolean isActive\n        datetime createdAt\n        datetime updatedAt\n    }\n\n    USER {\n        uuid id PK\n        uuid brandId \&quot;FK, nullable for Developers\&quot;\n        string email \&quot;UK\&quot;\n        string passwordHash\n        string firstName\n        string lastName\n        string phone \&quot;nullable\&quot;\n        uuid roleId FK\n        boolean isActive\n        datetime lastLogin \&quot;nullable\&quot;\n        datetime createdAt\n        datetime updatedAt\n    }\n\n    ROLE {\n        uuid id PK\n        string name \&quot;UK — Developer, Owner, Admin, Employee\&quot;\n        string description \&quot;nullable\&quot;\n    }\n\n    PERMISSION {\n        uuid id PK\n        string name \&quot;UK\&quot;\n        string description \&quot;nullable\&quot;\n    }\n\n    ROLE_PERMISSION {\n        uuid roleId PK, FK\n        uuid permissionId PK, FK\n    }\n\n    EMPLOYEE {\n        uuid id PK\n        uuid storeId FK\n        uuid userId \&quot;FK, UK\&quot;\n        string employeeCode \&quot;UK\&quot;\n        enum jobTitle \&quot;EmployeePosition\&quot;\n        decimal salary \&quot;Decimal(10,2), nullable\&quot;\n        date hireDate\n        boolean isActive\n        datetime createdAt\n        datetime updatedAt\n    }\n\n    CATEGORY {\n        uuid id PK\n        uuid brandId FK\n        string name \&quot;UK with Brand\&quot;\n        boolean isActive\n        datetime createdAt\n        datetime updatedAt\n    }\n\n    PRODUCT {\n        uuid id PK\n        uuid brandId FK\n        uuid categoryId FK\n        string barcode \&quot;UK (global)\&quot;\n        string sku \&quot;UK with Brand\&quot;\n        string name\n        string description \&quot;nullable\&quot;\n        decimal costPrice \&quot;Decimal(10,2)\&quot;\n        decimal sellingPrice \&quot;Decimal(10,2)\&quot;\n        decimal taxRate \&quot;Decimal(5,2)\&quot;\n        string image \&quot;nullable\&quot;\n        boolean isActive\n        datetime createdAt\n        datetime updatedAt\n    }\n\n    SUPPLIER {\n        uuid id PK\n        uuid brandId FK\n        string name\n        string email \&quot;nullable\&quot;\n        string phone \&quot;nullable\&quot;\n        string address \&quot;nullable\&quot;\n        boolean isActive\n        datetime createdAt\n        datetime updatedAt\n    }\n\n    PURCHASE {\n        uuid id PK\n        uuid storeId FK\n        uuid supplierId FK\n        uuid employeeId FK\n        datetime purchaseDate\n        string invoiceNumber \&quot;UK, nullable\&quot;\n        decimal totalAmount \&quot;Decimal(10,2)\&quot;\n        string notes \&quot;nullable\&quot;\n        datetime createdAt\n        datetime updatedAt\n    }\n\n    PURCHASE_ITEM {\n        uuid purchaseId PK, FK\n        uuid productId PK, FK\n        int quantity\n        decimal costPrice \&quot;Decimal(10,2)\&quot;\n    }\n\n    INVENTORY {\n        uuid storeId PK, FK\n        uuid productId PK, FK\n        int quantity\n        int minQuantity \&quot;nullable\&quot;\n        int maxQuantity \&quot;nullable\&quot;\n    }\n\n    INVENTORY_TRANSACTION {\n        uuid id PK\n        uuid storeId FK\n        uuid productId FK\n        uuid userId FK\n        enum type \&quot;InventoryTxType\&quot;\n        int quantity\n        string referenceType \&quot;nullable\&quot;\n        uuid referenceId \&quot;nullable\&quot;\n        string notes \&quot;nullable\&quot;\n        datetime createdAt\n    }\n\n    CUSTOMER {\n        uuid id PK\n        uuid brandId FK\n        string name\n        string phone \&quot;nullable\&quot;\n        string email \&quot;nullable\&quot;\n        int loyaltyPoints \&quot;default 0\&quot;\n        boolean isActive\n        datetime createdAt\n        datetime updatedAt\n    }\n\n    SALE {\n        uuid id PK\n        uuid storeId FK\n        uuid employeeId FK\n        uuid customerId \&quot;FK, nullable\&quot;\n        datetime saleDate\n        decimal totalAmount \&quot;Decimal(10,2)\&quot;\n        decimal discount \&quot;Decimal(10,2), default 0\&quot;\n        decimal tax \&quot;Decimal(10,2), auto-calculated\&quot;\n        datetime createdAt\n    }\n\n    SALE_ITEM {\n        uuid saleId PK, FK\n        uuid productId PK, FK\n        int quantity\n        decimal unitPrice \&quot;Decimal(10,2)\&quot;\n        decimal discount \&quot;Decimal(10,2), default 0\&quot;\n        decimal tax \&quot;Decimal(10,2), auto-calculated\&quot;\n    }\n\n    PAYMENT {\n        uuid id PK\n        uuid saleId FK\n        decimal amount \&quot;Decimal(10,2)\&quot;\n        enum method \&quot;PaymentMethod\&quot;\n    }\n\n    CASH_REGISTER {\n        uuid id PK\n        uuid storeId FK\n        string name\n        string number \&quot;nullable\&quot;\n        boolean isActive\n        datetime createdAt\n        datetime updatedAt\n    }\n\n    SHIFT {\n        uuid id PK\n        uuid employeeId FK\n        uuid cashRegisterId FK\n        datetime startTime\n        datetime endTime \&quot;nullable (ongoing shift)\&quot;\n        decimal openingCash \&quot;Decimal(10,2)\&quot;\n        decimal closingCash \&quot;Decimal(10,2), nullable\&quot;\n    }\n\n    OVERTIME_REQUEST {\n        uuid id PK\n        uuid employeeId FK\n        decimal hours \&quot;Decimal(5,1)\&quot;\n        string reason\n        enum status \&quot;OvertimeStatus\&quot;\n    }\n\n    REFUND {\n        uuid id PK\n        uuid saleId FK\n        uuid employeeId FK\n        uuid approvedBy \&quot;FK — User\&quot;\n        datetime refundDate\n        string reason\n        decimal amount \&quot;Decimal(10,2)\&quot;\n        enum status \&quot;RefundStatus\&quot;\n    }\n\n    NOTIFICATION {\n        uuid id PK\n        uuid userId FK\n        string title\n        string message\n        enum type \&quot;NotificationType\&quot;\n        boolean isRead \&quot;default false\&quot;\n        datetime createdAt\n    }\n\n    AUDIT_LOG {\n        uuid id PK\n        uuid userId \&quot;FK, nullable\&quot;\n        enum action \&quot;AuditAction\&quot;\n        string entity\n        uuid entityId\n        string oldValue \&quot;nullable\&quot;\n        string newValue \&quot;nullable\&quot;\n        string ipAddress \&quot;nullable\&quot;\n        datetime createdAt\n    }\n&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="1039">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=10;" vertex="1">
            <mxGeometry height="2869" width="3261.5" as="geometry" />
