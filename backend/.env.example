# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/store_management

# JWT
JWT_SECRET=change_me_to_a_random_64_char_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_another_random_64_char_string
JWT_REFRESH_EXPIRES_IN=7d

# SMTP (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@store.com

# CORS
CORS_ORIGIN=http://localhost:5173

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
